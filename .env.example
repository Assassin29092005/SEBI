# LLM provider keys — OPTIONAL. The demo, tests, and every user-facing
# feature run without any key configured (every LLM path has a deterministic
# fallback; see README.md "The whole system runs without any API key").
#
# Set one to enable the optional LLM enrichments: chattier examiner,
# LLM-assisted prose extraction from uploads, richer generated section prose
# (still gated by the digit-level hallucination guard).
GEMINI_API_KEY=
GROQ_API_KEY=

# Provider preference: "gemini" | "groq". Client picks the first configured
# provider — no key on either → LLMUnavailable → deterministic path.
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile

# Backend bind
API_HOST=127.0.0.1
API_PORT=8000
